": "#824EB2", "category": "Submission", "modifiers": "", "excluded": "Leave (non-agonistic)", "coding map": ""}, "51": {"type": "State event", "key": "", "code": "Cower/Crouch", "description": "Body lowered toward ground (may be motionless) at partner approach/threat.", "color": "#A680C8", "category": "Submission", "modifiers": "", "excluded": "", "coding map": ""}, "52": {"type": "State event", "key": "", "code": "Fear grimace", "description": "Corners of mouth pulled back exposing teeth (fear grimace).", "color": "#B89AD3", "category": "Submission", "modifiers": "", "excluded": "", "coding map": ""}, "53": {"type": "State event", "key": "", "code": "Submissive present", "description": "Hindquarters presentation in submissive/dominance context allowing mounting; not sexual solicitation.", "color": "#B89AD3", "category": "Submission", "modifiers": "", "excluded": "Sex present", "coding map": ""}, "54": {"type": "State event", "key": "", "code": "Scream", "description": "High-pitched cry given by recipient of aggression.", "color": "#704299", "category": "Submission", "modifiers": "", "excluded": "", "coding map": ""}, "55": {"type": "State event", "key": "", "code": "Flee", "description": "Rapid movement away from partner in response to aggression.", "color": "#824EB2", "category": "Submission", "modifiers": "", "excluded": "Leave (non-agonistic)", "coding map": ""}, "56": {"type": "State event", "key": "", "code": "Freeze/Ignore", "description": "No visible response to partner aggression/threat while oriented to it (\u22655 s).", "color": "#9467BD", "category": "Submission", "modifiers": "", "excluded": "Rest; Out-of-view", "coding map": ""}, "57": {"type": "State event", "key": "", "code": "Alarm bark", "description": "Characteristic alarm bark to perceived danger (often external).", "color": "#BCBD22", "category": "Attention", "modifiers": "", "excluded": "Aggressive vocal", "coding map": ""}, "58": {"type": "State event", "key": "", "code": "Other vocal", "descr