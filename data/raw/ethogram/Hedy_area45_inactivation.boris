{"time_format": "hh:mm:ss", "project_date": "2026-02-19T10:20:24", "project_name": "Hedy_area45_inactivation", "project_description": "", "project_format_version": "7.0", "subjects_conf": {}, "behaviors_conf": {"0": {"type": "State event", "key": "r", "code": "Rest/Stationary", "description": "Focal is motionless or minimally moving (postural adjustments only); not interacting; eyes may be open or closed.", "color": "#747474", "category": "Maintenance", "modifiers": "", "excluded": "Sleep (see Sleep); Self-groom; Forage/Eat/Drink; Social contact", "coding map": ""}, "1": {"type": "State event", "key": "", "code": "Sleep", "description": "Eyes closed for \u22655 s with relaxed posture; minimal movement.", "color": "#747474", "category": "Maintenance", "modifiers": "", "excluded": "Brief eye closure/blink; Rest with eyes open", "coding map": ""}, "2": {"type": "State event", "key": "g", "code": "Self-groom", "description": "Hands/teeth sweep through own fur/skin in a continuous bout (\u22655 s).", "color": "#8A8A8A", "category": "Maintenance", "modifiers": "", "excluded": "Scratch (rapid nail raking); Digit-suck (atypical)", "coding map": ""}, "3": {"type": "State event", "key": "s", "code": "Scratch", "description": "Rapid nail raking of skin (single scratch episode). New scratch when limb disengages or body region changes.", "color": "#8A8A8A", "category": "Maintenance", "modifiers": "", "excluded": "Self-groom bout", "coding map": ""}, "4": {"type": "State event", "key": "", "code": "Stretch", "description": "Full-body or limb extension/stretch, not part of locomotion.", "color": "#9F9F9F", "category": "Maintenance", "modifiers": "", "excluded": "", "coding map": ""}, "5": {"type": "State event", "key": "u", "code": "Urinate", "description": "Urination observed.", "color": "#5F5F5F", "category": "Maintenance", "modifiers": "", "excluded": "", "coding map": ""}, "6": {"type": "State event", "key": "d", "code": "Defecate", "description": "Defecation observed.", "color": "#5F5F5F", "category": "Maintenance", "modifiers": "", "excluded": "", "coding map": ""}, "7": {"type": "State event", "key": "t", "code": "Travel", "description": "Directed movement from one location to another (walking/running/climbing/leaping).", "color": "#FF7F0E", "category": "Locomotion", "modifiers": "", "excluded": "Pace; Chase", "coding map": ""}, "8": {"type": "State event", "key": "", "code": "Out-of-view", "description": "Focal not visible to observer for \u226515 s.", "color": "#8C564B", "category": "Other", "modifiers": "", "excluded": "", "coding map": ""}, "9": {"type": "State event", "key": "f", "code": "Forage/Search", "description": "Searching/handling substrate or enrichment for food (hand/mouth exploration) without ingesting yet.", "color": "#37C837", "category": "Feeding", "modifiers": "", "excluded": "Eat; Object play/manipulation (non-feeding)", "coding map": ""}, "10": {"type": "State event", "key": "e", "code": "Eat", "description": "Ingesting food (chewing/swallowing) including holding food while chewing.", "color": "#217821", "category": "Feeding", "modifiers": "", "excluded": "Non-food chew (e.g., collar chew)", "coding map": ""}, "11": {"type": "State event", "key": "d", "code": "Drink", "description": "Drinking water (sipper/pipe) or licking water from hand/surface.", "color": "#217821", "category": "Feeding", "modifiers": "", "excluded": "", "coding map": ""}, "12": {"type": "State event", "key": "c", "code": "Chew non-food", "description": "Chewing/manipulating non-food item with mouth (e.g., collar loop, cage bar) without ingesting.", "color": "#694138", "category": "Other", "modifiers": "", "excluded": "Eat", "coding map": ""}, "13": {"type": "State event", "key": "o", "code": "Object manipulate", "description": "Manual manipulation/exploration of non-food objects (logger/toy/cage fixture) without clear social intent.", "color": "#694138", "category": "Other", "modifiers": "", "excluded": "Forage; Aggressive cage-shake display", "coding map": ""}, "14": {"type": "State event", "key": "v", "code": "Vigilant/Scan", "description": "Stationary with sustained scanning of environment (head/eye movements), attentive posture.", "color": "#BCBD22", "category": "Attention", "modifiers": "", "excluded": "Gaze at partner during social interaction; Alert outside-personnel", "coding map": ""}, "15": {"type": "State event", "key": "", "code": "Attention to outside agents", "description": "Focal directs head to outside the cage due to noise/movement of monkeys that are in different cages/enclosures or personnel in the room. It does not require stopping its current behavior (e.g. grooming)", "color": "#BCBD22", "category": "Attention", "modifiers": "", "excluded": "Vigilant/Scan", "coding map": ""}, "16": {"type": "State event", "key": "a", "code": "Approach (non-agonistic)", "description": "Focal moves to within arm\u2019s reach (~60 cm) of partner and remains \u22655 s without threat.", "color": "#1A6599", "category": "Affiliative", "modifiers": "", "excluded": "Approach as part of aggression (charge/lunge) or mounting", "coding map": ""}, "17": {"type": "State event", "key": "l", "code": "Leave/Withdraw (non-agonistic)", "description": "Focal moves from within arm\u2019s reach to beyond arm\u2019s reach of partner.", "color": "#1A6599", "category": "Affiliative", "modifiers": "", "excluded": "Flee/jump-away in response to aggression", "coding map": ""}, "18": {"type": "State event", "key": "p", "code": "Proximity (<arm\u2019s reach)", "description": "Focal remains within arm\u2019s reach of partner without physical contact.", "color": "#2D94DB", "category": "Affiliative", "modifiers": "", "excluded": "Sitting-with/contact; Grooming; Mounting; Aggression", "coding map": ""}, "19": {"type": "State event", "key": "", "code": "Contact/Sit-with", "description": "Any sustained physical contact (sitting/lying/sleeping in contact) with partner (\u22655 s).", "color": "#1D71AB", "category": "Affiliative", "modifiers": "", "excluded": "Grooming; Mounting; Fight", "coding map": ""}, "20": {"type": "State event", "key": "t", "code": "Affiliative touch", "description": "Brief gentle touch/hand contact to partner (non-grab, non-aggressive).", "color": "#1D71AB", "category": "Affiliative", "modifiers": "", "excluded": "Grab (aggressive); Groom", "coding map": ""}, "21": {"type": "State event", "key": "l", "code": "Lip-smack", "description": "Rapid lip movement producing smacking sound; affiliative signal (record actor).", "color": "#175987", "category": "Affiliative", "modifiers": "", "excluded": "Mouth-open threat; Teeth-grind (atypical)", "coding map": ""}, "22": {"type": "State event", "key": "", "code": "Muzzle-muzzle contact", "description": "Nose/mouth contact with partner\u2019s mouth/nose in non-aggressive manner.", "color": "#175987", "category": "Affiliative", "modifiers": "", "excluded": "Bite; Mouth-open threat", "coding map": ""}, "23": {"type": "State event", "key": "z", "code": "Groom give", "description": "Focal grooms partner: running hands/mouth through fur.", "color": "#00FFFF", "category": "Affiliative", "modifiers": "", "excluded": "", "coding map": ""}, "24": {"type": "State event", "key": "x", "code": "Groom receive", "description": "Partner grooms focal.", "color": "#0000FF", "category": "Affiliative", "modifiers": "", "excluded": "", "coding map": ""}, "25": {"type": "State event", "key": "s", "code": "Groom solicit", "description": "Focal presents body/positions or gestures to invite grooming without sexual presentation.", "color": "#217DBD", "category": "Affiliative", "modifiers": "", "excluded": "Present (dominance/sexual)", "coding map": ""}, "26": {"type": "State event", "key": "p", "code": "Sex present", "description": "Focal presents genital area to partner (sexual context).", "color": "#F2BFE2", "category": "Sexual", "modifiers": "", "excluded": "Present for dominance (submissive)", "coding map": ""}, "27": {"type": "State event", "key": "m", "code": "Mount attempt", "description": "Unsuccessful mount attempt; recipient moves away before completion.", "color": "#E377C2", "category": "Sexual", "modifiers": "", "excluded": "", "coding map": ""}, "28": {"type": "State event", "key": "m", "code": "Mount give", "description": "Mounting posture with focal as mounter (may include thrusts).", "color": "#E377C2", "category": "Sexual", "modifiers": "", "excluded": "Dominance mount (no thrusts) if distinguished", "coding map": ""}, "29": {"type": "State event", "key": "m", "code": "Mount receive", "description": "Focal is mounted by partner.", "color": "#E377C2", "category": "Sexual", "modifiers": "", "excluded": "", "coding map": ""}, "30": {"type": "State event", "key": "", "code": "Intromission", "description": "Mount includes intromission (record within Mount bout).", "color": "#DC53B2", "category": "Sexual", "modifiers": "", "excluded": "", "coding map": ""}, "31": {"type": "State event", "key": "", "code": "Ejaculation", "description": "Cessation of thrusting with semen emission during mount (record within Mount bout).", "color": "#DC53B2", "category": "Sexual", "modifiers": "", "excluded": "", "coding map": ""}, "32": {"type": "State event", "key": "", "code": "Genital inspect", "description": "Inspection of partner genital area (sniff/lick) without mounting.", "color": "#EA9BD2", "category": "Sexual", "modifiers": "", "excluded": "Muzzle-muzzle; Groom", "coding map": ""}, "33": {"type": "State event", "key": "m", "code": "Masturbate", "description": "Manual stimulation of own genitals (not self-groom).", "color": "#D42FA2", "category": "Sexual", "modifiers": "", "excluded": "Genital suck (atypical)", "coding map": ""}, "34": {"type": "State event", "key": "t", "code": "Stare threat", "description": "Intense glare at partner often with ears pinned; no mouth open.", "color": "#DF4E4F", "category": "Aggression", "modifiers": "", "excluded": "", "coding map": ""}, "35": {"type": "State event", "key": "t", "code": "Open-mouth threat", "description": "Stare with mouth open in aggressive manner; no contact.", "color": "#DF4E4F", "category": "Aggression", "modifiers": "", "excluded": "", "coding map": ""}, "36": {"type": "State event", "key": "t", "code": "Head-bob threat", "description": "Rapid lifting/lowering of head during threat display.", "color": "#DF4E4F", "category": "Aggression", "modifiers": "", "excluded": "", "coding map": ""}, "37": {"type": "State event", "key": "", "code": "Lunge/Charge", "description": "Sudden burst/lunge toward partner without sustained chase; may stop short.", "color": "#AE2020", "category": "Aggression", "modifiers": "", "excluded": "Approach (non-agonistic); Chase", "coding map": ""}, "38": {"type": "State event", "key": "v", "code": "Aggressive vocal", "description": "Huh vocalization in aggressive context", "color": "#E15B5C", "category": "Aggression", "modifiers": "", "excluded": "Alarm bark to danger outside cage", "coding map": ""}, "39": {"type": "State event", "key": "", "code": "Enlist/Recruit", "description": "Looks over shoulder or orients to solicit support while threatening opponent.", "color": "#DC4041", "category": "Aggression", "modifiers": "", "excluded": "", "coding map": ""}, "40": {"type": "State event", "key": "", "code": "Slap ground", "description": "Slaps palm on ground/surface as threat display.", "color": "#C92525", "category": "Aggression", "modifiers": "", "excluded": "", "coding map": ""}, "41": {"type": "State event", "key": "c", "code": "Cage-shake display", "description": "Vigorous shaking/rocking of cage/perch during arousal/threat.", "color": "#C92525", "category": "Aggression", "modifiers": "", "excluded": "Object manipulate (non-display)", "coding map": ""}, "42": {"type": "State event", "key": "", "code": "Displacement", "description": "Focal approaches partner (\u2264arm reach) causing partner to leave, then focal takes space/food/water/partner; no contact.", "color": "#A01D1E", "category": "Aggression",